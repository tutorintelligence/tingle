<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened runtime strips capabilities unless re-granted here.
         Mic: beacon detection + dictation capture. Apple Events: the
         summon-agent shell scripts drive apps via osascript, attributed
         to tingle as the responsible process. Not sandboxed. -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
    <key>com.apple.security.automation.apple-events</key>
    <true/>
</dict>
</plist>
